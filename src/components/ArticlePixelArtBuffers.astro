---
import PixelArtBufferViews from "./PixelArtBufferViews";
---

<div class="pixel-buffer-article">
  <div class="pixel-buffer-article__header">
    <div class="pixel-buffer-article__dots" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <span>Buffer Views</span>
    <span>live scene</span>
  </div>
  <div class="pixel-buffer-article__body">
    <PixelArtBufferViews client:load />
  </div>
</div>

<style>
  .pixel-buffer-article {
    margin: 2rem 0;
    border: 1px solid var(--border);
    background: var(--code-bg);
  }

  .pixel-buffer-article__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pixel-buffer-article__dots {
    display: flex;
    gap: 0.35rem;
  }

  .pixel-buffer-article__dots span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
  }

  .pixel-buffer-article__dots span:first-child {
    background: var(--window-dot-red);
  }

  .pixel-buffer-article__dots span:nth-child(2) {
    background: var(--window-dot-yellow);
  }

  .pixel-buffer-article__dots span:nth-child(3) {
    background: var(--window-dot-green);
  }

  .pixel-buffer-article__body {
    padding: 1rem;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__panel) {
    border: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(238, 243, 251, 0.04), rgba(238, 243, 251, 0.02));
    min-width: 0;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__viewport) {
    height: 15rem;
    background: #0b0f15;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__viewport canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .pixel-buffer-article__body :global(.pixel-buffer-demo) {
      grid-template-columns: 1fr;
    }
  }
</style>
