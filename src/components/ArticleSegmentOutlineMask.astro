---
import PixelArtBufferViews from "./PixelArtBufferViews";
---

<div class="pixel-buffer-article">
  <div class="pixel-buffer-article__header">
    <div class="pixel-buffer-article__dots" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <span>Segment Outline Mask</span>
    <span>live pass</span>
  </div>
  <div class="pixel-buffer-article__body">
    <PixelArtBufferViews mode="segmentEdgesOnly" client:load />
  </div>
</div>

<style>
  .pixel-buffer-article {
    margin: 2rem 0;
    border: 1px solid var(--border);
    background: var(--code-bg);
  }

  .pixel-buffer-article__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pixel-buffer-article__dots {
    display: flex;
    gap: 0.35rem;
  }

  .pixel-buffer-article__dots span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
  }

  .pixel-buffer-article__dots span:first-child {
    background: var(--window-dot-red);
  }

  .pixel-buffer-article__dots span:nth-child(2) {
    background: var(--window-dot-yellow);
  }

  .pixel-buffer-article__dots span:nth-child(3) {
    background: var(--window-dot-green);
  }

  .pixel-buffer-article__body {
    padding: 0;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo) {
    display: grid;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__controls) {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--border);
    background: var(--code-bg);
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__control-row) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__control) {
    display: grid;
    grid-template-columns: 10.5rem minmax(0, 1fr);
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1rem;
    color: var(--text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__control select) {
    width: auto;
    min-width: fit-content;
    justify-self: end;
    margin: 0;
    appearance: none;
    padding: 0.45rem 0.55rem;
    border: 1px solid var(--border);
    background: var(--panel-bg);
    color: var(--text);
    font: inherit;
    font-family: "DM Mono", monospace;
    line-height: 1.2;
    letter-spacing: 0.05em;
    text-align: center;
    text-align-last: center;
    text-transform: none;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__viewport) {
    height: 15rem;
    background: #0b0f15;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__viewport--solo) {
    height: 15rem;
  }

  .pixel-buffer-article__body :global(.pixel-buffer-demo__viewport canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
