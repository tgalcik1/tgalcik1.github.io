---
const links = [
  { href: "#about",    label: "About" },
  { href: "#work", label: "Work" },
  { href: "#skills",   label: "Skills" },
  { href: "#contact",  label: "Contact" },
];
---
<nav class="sticky top-4 z-50 flex justify-center">
  <div
    class="w-fit inline-flex items-center h-10 px-6 gap-4 sm:gap-6
           rounded-2xl border-[1.5px] border-white/10
           bg-slate-500/5 backdrop-blur-lg shadow-lg text-white"
  >
    <!-- Brand (smooth-scrolls to top on homepage) -->
    <a
      href="/"
      data-brand
      class="tracking-tight text-sm transition hover:text-[var(--brand)] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded"
    >
      Tristan Galcik
    </a>

    <!-- Vertical divider -->
    <span class="h-5 w-px bg-white/15" aria-hidden="true"></span>

    <div class="flex items-center gap-4 sm:gap-6 text-sm tracking-tight whitespace-nowrap">
      {links.map(l => (
        <a
          href={l.href}
          class="transition hover:text-[var(--brand)] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded"
        >
          {l.label}
        </a>
      ))}
    </div>

    <span class="h-5 w-px bg-white/15" aria-hidden="true"></span>

            <a
          href="/blog"
          class="tracking-tight text-sm transition hover:text-[var(--brand)] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded"
        >
          Blog
        </a>
  </div>
</nav>

<!-- Smooth scroll to top when clicking brand on the homepage -->
<script is:inline>
  const brand = document.querySelector('a[data-brand]');
  brand?.addEventListener('click', (e) => {
    const isPlainLeftClick = e.button === 0 && !e.metaKey && !e.ctrlKey && !e.shiftKey && !e.altKey;
    if (!isPlainLeftClick) return;

    if (location.pathname === '/' || location.pathname.endsWith('/index.html')) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
