---
import ShaderCanvas from "./ShaderCanvas";
import { activeTheme } from "../themes";

interface Props {
  id: string;
  title: string;
  date?: string;
  category: string;
  stack: string;
  description: string;
  accent?: string;
  preview?: {
    type: "shader" | "ui" | "typography" | "editorial";
    variant?: "warm" | "teal" | "plum";
    label?: string;
  };
}

const {
  id,
  title,
  date,
  category,
  stack,
  description,
  accent = "warm",
  preview = { type: "ui", label: "Project preview" }
} = Astro.props;
---

<article class="project-card card">
  <div class="project-card__top">
    <div class="project-card__meta">
      <span class="project-card__id">{id}</span>
      <span class={`project-card__kind accent-${accent}`}>{category}</span>
    </div>
    <span class="project-card__stack">{stack}</span>
  </div>
  <div class={`project-card__preview project-card__preview--${preview.type}`}>
    {
      preview.type === "shader" && (
        <>
          <ShaderCanvas client:load variant={preview.variant ?? activeTheme.shaderVariant} compact />
          <span class="project-card__preview-label">{preview.label}</span>
        </>
      )
    }

    {
      preview.type === "ui" && (
        <div class="project-card__ui-mock" aria-hidden="true">
          <div class="project-card__ui-toolbar">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="project-card__ui-body">
            <aside></aside>
            <div class="project-card__ui-board">
              <div></div>
              <div></div>
              <div></div>
              <div></div>
            </div>
          </div>
        </div>
      )
    }

    {
      preview.type === "typography" && (
        <div class="project-card__type-mock" aria-hidden="true">
          <span>A</span>
          <span>R</span>
          <span>C</span>
        </div>
      )
    }

    {
      preview.type === "editorial" && (
        <div class="project-card__editorial-mock" aria-hidden="true">
          <div class="project-card__editorial-top"></div>
          <div class="project-card__editorial-lines">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      )
    }
  </div>
  <div class="project-card__title-row">
    <h3>{title}</h3>
    {date && <p class="project-card__date">{date}</p>}
  </div>
  <p class="project-card__description">{description}</p>
</article>

<style>
  .project-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.25rem;
    min-height: 18rem;
  }

  .project-card__preview {
    position: relative;
    height: 8.5rem;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--preview-surface-soft), transparent);
    overflow: hidden;
  }

  .project-card__preview :global(canvas) {
    width: 100%;
    height: 100%;
  }

  .project-card__preview-label {
    position: absolute;
    left: 0.8rem;
    bottom: 0.75rem;
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .project-card__ui-mock,
  .project-card__editorial-mock {
    display: grid;
    width: 100%;
    height: 100%;
  }

  .project-card__ui-toolbar {
    display: flex;
    gap: 0.35rem;
    align-items: center;
    padding: 0.75rem 0.85rem 0;
  }

  .project-card__ui-toolbar span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--text-muted);
  }

  .project-card__ui-body {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.85rem;
    padding: 0.75rem;
  }

  .project-card__ui-body aside {
    border: 1px solid var(--preview-border-soft);
    background: var(--preview-surface-soft);
  }

  .project-card__ui-board {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .project-card__ui-board div {
    border: 1px solid var(--preview-border-soft);
    background:
      radial-gradient(circle at top left, var(--preview-accent-soft), transparent 60%),
      var(--preview-surface-soft);
  }

  .project-card__type-mock {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding: 0 1rem;
    background:
      radial-gradient(circle at 20% 20%, var(--preview-accent-soft), transparent 36%),
      linear-gradient(180deg, var(--preview-surface-soft), transparent);
  }

  .project-card__type-mock span {
    font-family: "Fraunces", serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    color: var(--preview-type-ink);
    transform: rotate(-10deg);
  }

  .project-card__type-mock span:nth-child(2) {
    transform: translateY(0.4rem) rotate(8deg);
    color: var(--preview-type-accent);
  }

  .project-card__editorial-top {
    height: 2rem;
    border-bottom: 1px solid var(--preview-border-soft);
    background:
      linear-gradient(90deg, var(--preview-accent-strong) 0 28%, transparent 28% 100%),
      var(--preview-surface-soft);
  }

  .project-card__editorial-lines {
    display: grid;
    gap: 0.55rem;
    padding: 0.8rem 0.85rem 0;
  }

  .project-card__editorial-lines span {
    display: block;
    height: 0.55rem;
    background: var(--preview-border-soft);
  }

  .project-card__editorial-lines span:nth-child(1) {
    width: 82%;
  }

  .project-card__editorial-lines span:nth-child(2) {
    width: 96%;
  }

  .project-card__editorial-lines span:nth-child(3) {
    width: 76%;
  }

  .project-card__editorial-lines span:nth-child(4) {
    width: 64%;
  }

  .project-card__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    min-height: 1.1rem;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .project-card__id,
  .project-card__kind,
  .project-card__stack {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-card__stack {
    color: var(--text-muted);
    text-align: right;
    line-height: 1;
    align-self: center;
  }

  .project-card__kind {
    white-space: nowrap;
    line-height: 1;
  }

  .project-card__id {
    line-height: 1;
  }

  .project-card h3 {
    font-size: 1.5rem;
  }

  .project-card__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-card__title-row h3 {
    margin: 0;
    min-width: 0;
    line-height: 1.05;
  }

  .project-card__date {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
    text-align: right;
    line-height: 1;
    flex-shrink: 0;
    transform: translateY(0.08rem);
  }

  .project-card__description {
    color: var(--text-soft);
    min-height: 3.9em;
    margin-top: 0;
  }

  @media (max-width: 900px) {
    .project-card__description {
      min-height: 0;
      margin-top: 0;
    }
  }

  @media (max-width: 640px) {
    .project-card__top {
      gap: 0.75rem;
    }

    .project-card__title-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .project-card__date {
      text-align: left;
    }

    .project-card__meta {
      gap: 0.5rem;
      flex-wrap: wrap;
    }
  }
</style>
