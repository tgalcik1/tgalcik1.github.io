---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { site } from "../data/site";
---

<BaseLayout title={`${site.name} | About`} description={site.aboutIntro}>
  <Header />
  <main class="about-page shell">
    <section class="about-hero section-gap">
      <div class="section-heading">
        <p class="eyebrow">About</p>
        <div class="about-hero__title-row">
          <h1>{site.name}</h1>
          <img class="about-hero__avatar" src={site.aboutImagePath} alt={site.name} />
        </div>
      </div>
    </section>

    <section class="about-grid">
      <div class="about-card about-card--writing panel">
        <div class="about-copy">
          {site.aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="about-links">
          {
            site.socialLinks.map((link) => (
              <a href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">
                <SocialIcon kind={link.label} />
                {link.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="about-card about-card--image panel">
        <img src={site.aboutImagePath} alt={site.name} />
      </div>
    </section>

    <section class="about-facts-section panel">
      <div class="about-facts">
        {
          site.aboutFacts.map((fact) => (
            <div class="about-fact">
              <span>{fact.label}</span>
              <p>{fact.value}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about-page {
    display: grid;
    gap: 2rem;
  }

  .about-hero {
    padding-top: 2rem;
  }

  .about-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 0.96;
  }

  .about-hero__title-row {
    display: block;
  }

  .about-hero__avatar {
    display: none;
  }

  .about-hero .section-heading {
    gap: 0.55rem;
    margin-bottom: 1.25rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .about-card {
    padding: 1.5rem;
  }

  .about-card--image {
    position: relative;
    padding: 0;
    overflow: hidden;
    min-height: 100%;
  }

  .about-card--image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) contrast(1.03);
  }

  .about-card--writing {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 1.5rem;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .about-copy p {
    max-width: 42rem;
  }

  .about-facts-section {
    padding: 1px;
  }

  .about-facts {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--border);
  }

  .about-fact {
    display: grid;
    gap: 0.45rem;
    padding: 1rem 1.1rem 1.15rem;
    background: var(--card-bg);
  }

  .about-fact span {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .about-fact p {
    color: var(--text);
  }

  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-self: start;
  }

  .about-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.7rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .about-hero {
      padding-top: 2rem;
    }

    .about-facts {
      grid-template-columns: 1fr;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-hero__title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .about-hero__avatar {
      display: block;
      width: 4.5rem;
      height: 4.5rem;
      flex: 0 0 4.5rem;
      border-radius: 999px;
      object-fit: cover;
      object-position: center;
      filter: grayscale(1) contrast(1.03);
      border: 1px solid var(--border);
    }

    .about-card--image {
      display: none;
    }
  }
</style>
