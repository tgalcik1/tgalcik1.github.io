---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostPreviewCard from "../../components/PostPreviewCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout title="Writing | Tristan Galcik" description="Notes on graphics, full-stack work, and interactive systems.">
  <Header />
  <main class="shell">
    <section class="blog-hero">
      <p class="eyebrow">Writing</p>
      <h1>What I'm working on</h1>
      <p>
       Technical breakdowns, shader experiments, implementation notes, and other thoughts
      </p>
    </section>

    <section class="section-gap">
      <div class="grid-border blog-grid panel">
        {posts.map((post) => (
          <PostPreviewCard
            href={`/blog/${post.data.slug}/`}
            category={post.data.category}
            title={post.data.title}
            description={post.data.description}
            publishedAt={post.data.publishedAt}
            thumbnail={post.data.thumbnail}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-hero {
    width: min(100%, 54rem);
    padding-top: 4rem;
  }

  .blog-hero h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.98;
  }

  .blog-hero p:last-child {
    margin-top: 1rem;
    color: var(--text-soft);
  }

  .blog-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
    background: transparent;
    border: 0;
    padding: 0;
  }

  .blog-grid :global(.post-preview) {
    display: grid;
    grid-template-columns: 13rem minmax(0, 1fr);
    align-items: stretch;
    gap: 0;
    min-height: 0;
  }

  .blog-grid :global(.post-preview__media) {
    grid-column: 1;
    grid-row: 1;
    width: 13rem;
    height: 10rem;
  }

  .blog-grid :global(.post-preview__content) {
    grid-column: 2;
    grid-row: 1;
  }

  .blog-grid :global(.post-preview__body p) {
    max-width: 48rem;
  }

  @media (max-width: 960px) {
    .blog-grid :global(.post-preview) {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .blog-grid :global(.post-preview__media) {
      grid-column: auto;
      grid-row: auto;
      border-right: 0;
      border-bottom: 1px solid var(--border);
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 10;
    }

    .blog-grid :global(.post-preview__content) {
      grid-column: auto;
      grid-row: auto;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 0 1.25rem 1.25rem;
    }

    .blog-grid :global(.post-preview time) {
      text-align: left;
    }
  }
</style>
