---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostPreviewCard from "../../components/PostPreviewCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout title="Writing | Tristan Galcik" description="Notes on graphics, full-stack work, and interactive systems.">
  <Header />
  <main class="shell">
    <section class="blog-hero">
      <p class="eyebrow">Writing</p>
      <h1>Posts that can hold code, shaders, and actual implementation detail.</h1>
      <p>
        The blog is meant to support technical notes, visual experiments, and longer breakdowns instead of generic
        portfolio filler.
      </p>
    </section>

    <section class="section-gap">
      <div class="grid-border blog-grid">
        {posts.map((post) => (
          <PostPreviewCard
            href={`/blog/${post.data.slug}/`}
            category={post.data.category}
            title={post.data.title}
            description={post.data.description}
            publishedAt={post.data.publishedAt}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-hero {
    width: min(100%, 54rem);
    padding-top: 4rem;
  }

  .blog-hero h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.98;
  }

  .blog-hero p:last-child {
    margin-top: 1rem;
    color: var(--text-soft);
  }

  .blog-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 960px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
