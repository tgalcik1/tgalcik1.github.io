---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostPreviewCard from "../../components/PostPreviewCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<BaseLayout title="Writing | Tristan Galcik" description="Notes on graphics, full-stack work, and interactive systems.">
  <Header />
  <main class="shell">
    <section class="blog-hero">
      <p class="eyebrow">Writing</p>
      <h1>What I'm working on</h1>
      <p>
       Technical breakdowns, shader experiments, implementation notes, and other thoughts
      </p>
    </section>

    <section class="section-gap">
      <div class="grid-border blog-grid">
        {posts.map((post) => (
          <PostPreviewCard
            href={`/blog/${post.data.slug}/`}
            category={post.data.category}
            title={post.data.title}
            description={post.data.description}
            publishedAt={post.data.publishedAt}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-hero {
    width: min(100%, 54rem);
    padding-top: 4rem;
  }

  .blog-hero h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.98;
  }

  .blog-hero p:last-child {
    margin-top: 1rem;
    color: var(--text-soft);
  }

  .blog-grid {
    grid-template-columns: 1fr;
  }

  .blog-grid :global(.post-preview) {
    display: grid;
    grid-template-columns: minmax(0, 11rem) minmax(0, 1fr) auto;
    align-items: start;
    gap: 1rem 1.5rem;
    min-height: 0;
  }

  .blog-grid :global(.post-preview__category) {
    grid-column: 1;
    grid-row: 1 / span 2;
    padding-top: 0.3rem;
  }

  .blog-grid :global(.post-preview h3) {
    grid-column: 2;
    grid-row: 1;
  }

  .blog-grid :global(.post-preview p) {
    grid-column: 2;
    grid-row: 2;
    max-width: 48rem;
  }

  .blog-grid :global(.post-preview time) {
    grid-column: 3;
    grid-row: 1;
    padding-top: 0.45rem;
    text-align: right;
  }

  @media (max-width: 960px) {
    .blog-grid :global(.post-preview) {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .blog-grid :global(.post-preview__category),
    .blog-grid :global(.post-preview h3),
    .blog-grid :global(.post-preview p),
    .blog-grid :global(.post-preview time) {
      grid-column: auto;
      grid-row: auto;
      padding-top: 0;
      text-align: left;
    }
  }
</style>
