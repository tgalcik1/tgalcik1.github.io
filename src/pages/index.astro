<script is:inline>
  const initHeroCarousel = () => {
    const visual = document.querySelector(".hero__visual");
    const carousel = visual?.querySelector("[data-demo-carousel]");
    if (!(carousel instanceof HTMLElement) || !(visual instanceof HTMLElement)) return;

    const slides = Array.from(carousel.querySelectorAll("[data-demo-slide]"));
    const dots = Array.from(visual.querySelectorAll("[data-demo-dot]"));
    const prev = visual.querySelector("[data-demo-prev]");
    const next = visual.querySelector("[data-demo-next]");
    let index = 0;

    const render = () => {
      const activeSlide = slides[index];
      const chrome = activeSlide?.getAttribute("data-demo-chrome") ?? "framed";
      carousel.setAttribute("data-demo-chrome", chrome);

      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle("is-active", slideIndex === index);
      });

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("is-active", dotIndex === index);
        dot.setAttribute("aria-selected", dotIndex === index ? "true" : "false");
      });
    };

    prev?.addEventListener("click", () => {
      index = (index - 1 + slides.length) % slides.length;
      render();
    });

    next?.addEventListener("click", () => {
      index = (index + 1) % slides.length;
      render();
    });

    dots.forEach((dot, dotIndex) => {
      dot.addEventListener("click", () => {
        index = dotIndex;
        render();
      });
    });

    render();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroCarousel, { once: true });
  } else {
    initHeroCarousel();
  }
</script>

<style>
  .hero-wrap {
    position: relative;
    isolation: isolate;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 2rem;
    padding-top: 4rem;
    align-items: stretch;
  }

  .hero__copy {
    position: relative;
    z-index: 1;
  }

  .hero__copy h1 {
    font-size: clamp(3.9rem, 9vw, 7rem);
    line-height: 0.95;
  }

  .hero__copy h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero__copy h1 span {
    color: var(--text-muted);
  }

  .hero__lede {
    max-width: 34rem;
    margin: 1.5rem 0 2rem;
    font-size: 0.95rem;
  }

  .disabled-cta {
    position: relative;
    display: inline-block;
    isolation: isolate;
  }

  .disabled-cta__tooltip {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.5rem);
    transform: translateX(-50%) translateY(-0.2rem);
    padding: 0.4rem 0.55rem;
    border: 1px solid var(--border);
    background: var(--code-bg);
    color: var(--text);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease;
    z-index: 3;
  }

  .disabled-cta:hover .disabled-cta__tooltip,
  .disabled-cta:focus-within .disabled-cta__tooltip {
    visibility: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .hero__visual {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-self: stretch;
    position: relative;
    z-index: 1;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .hero__visual-main {
    position: relative;
    flex: 1;
    min-height: clamp(27.5rem, 38vw, 32rem);
    background: transparent;
    overflow: hidden;
  }

  .hero__visual-main::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--border);
    background: var(--panel-bg);
    pointer-events: none;
    z-index: 0;
  }

  .hero__visual-main[data-demo-chrome="none"]::before {
    border: 0;
    background: transparent;
  }

  .hero__demo {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease;
    overflow: hidden;
  }

  .hero__demo::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--border);
    background: var(--panel-bg);
    pointer-events: none;
    z-index: 0;
  }

  .hero__demo[data-demo-chrome="none"]::before {
    border: 0;
    background: transparent;
  }

  .hero__demo.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero__demo > :not(span) {
    position: relative;
    z-index: 1;
  }

  .hero__demo span {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    z-index: 2;
  }

  .hero__visual-main :global(canvas) {
    width: 100%;
    height: 100%;
  }

  .hero__visual-main :global(.pixelated-study) {
    width: 100%;
    height: 100%;
  }

  .hero__visual-main :global(.pixelated-study canvas) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero__visual-controls {
    display: grid;
    place-items: center;
    align-items: center;
    min-height: 4.25rem;
    padding: 0.75rem 1rem;
  }

  .hero__visual-controls-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
  }

  .hero__visual-arrow {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.3rem;
    height: 2.3rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-muted);
    font: inherit;
    line-height: 1;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease, background-color 180ms ease;
  }

  .hero__visual-arrow:hover {
    border-color: rgba(243, 231, 216, 0.24);
    color: var(--text);
  }

  .hero__visual-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    flex: 1;
  }

  .hero__visual-dot {
    appearance: none;
    -webkit-appearance: none;
    width: 0.52rem;
    height: 0.52rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: var(--text-muted);
    opacity: 0.45;
    cursor: pointer;
    transition: transform 180ms ease, opacity 180ms ease, background-color 180ms ease;
  }

  .hero__visual-dot.is-active {
    background: var(--accent);
    opacity: 1;
    transform: scale(1.15);
  }

  .projects-grid,
  .writing-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cta__panel {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 1.5rem;
    padding: 1.5rem;
  }

  .cta__actions {
    display: grid;
    gap: 1.25rem;
    align-content: start;
  }

  .projects-grid {
    padding: 1px;
  }

  .writing-grid {
    padding: 1px;
  }

  @media (max-width: 900px) {
    .hero,
    .cta__panel,
    .projects-grid,
    .writing-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      grid-template-columns: 1fr;
      padding-top: 2rem;
    }

    .hero__copy {
      padding-top: 0;
    }

    .hero__visual-controls {
      min-height: 3.75rem;
      padding: 0 0.8rem;
    }
  }
</style>
